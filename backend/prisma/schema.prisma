generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model SyncLog {
  platform     String    @id
  lastSyncedAt DateTime
  syncedFrom   DateTime?
  syncedTo     DateTime?
}

model IgAccount {
  id         Int      @id @default(1)
  followers  Int      @default(0)
  username   String   @default("")
  views      Int      @default(0)
  baseReach  Int      @default(0)
  updatedAt  DateTime
}

model IgDailyMetric {
  date     String   @id
  reach    Int      @default(0)
  syncedAt DateTime
}

model IgFollowerSnapshot {
  date      String   @id
  followers Int      @default(0)
  syncedAt  DateTime
}

model Lead {
  id              Int      @id @default(autoincrement())
  displayName     String?
  instagramHandle String?
  eventName       String?
  eventDate       String?
  eventLocation   String?
  contactEmail    String?
  contactPhone    String?
  collaborators   String   @default("[]")
  status          String   @default("Not Contacted")
  notes           String   @default("")
  dateAdded       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model IgPost {
  id             String   @id
  mediaType      String   @default("")
  thumbnail      String   @default("")
  caption        String   @default("")
  likes          Int      @default(0)
  comments       Int      @default(0)
  shares         Int      @default(0)
  saves          Int      @default(0)
  reach          Int      @default(0)
  views          Int      @default(0)
  impressions    Int      @default(0)
  profileVisits  Int      @default(0)
  follows        Int      @default(0)
  engagementRate Float    @default(0)
  avgWatchTime   Int      @default(0)
  videoDuration  Float    @default(0)
  postedAt       String   @default("")
  syncedAt       DateTime
}

// ── VBV Creative Pipeline ──────────────────────────────────────────────────

model VbvUser {
  id                   String             @id @default(uuid())
  name                 String
  email                String             @unique
  passwordHash         String
  role                 VbvRole
  isActive             Boolean            @default(true)
  sermonPipelineAccess Boolean            @default(false)
  createdAt            DateTime           @default(now())
  credential           VbvUserCredential?
  createdJobs          VbvJob[]           @relation("CreatedBy")
  assignedJobs         VbvJob[]           @relation("AssignedTo")
  submissions          VbvSubmission[]
  smReviews            VbvSubmission[]    @relation("SmReviewer")
  timelineLogs         VbvTimelineLog[]
  activityLogs         VbvActivityLog[]
}

enum VbvRole {
  social_media
  editor
  lead_editor
  admin
  vedits
}

model VbvUserCredential {
  id            String   @id @default(uuid())
  userId        String   @unique
  email         String
  plainPassword String
  createdAt     DateTime @default(now())
  user          VbvUser  @relation(fields: [userId], references: [id])
}

model VbvJob {
  id               String          @id @default(uuid())
  title            String
  artistName       String
  briefType        VbvBriefType
  sourceDriveLink  String
  startTimestamp   String?
  endTimestamp     String?
  clipNotes        String?
  editInstructions String?
  platformTargets  String[]
  deadline         DateTime
  status           VbvJobStatus    @default(open)
  createdById      String
  assignedToId     String?
  claimedAt        DateTime?
  createdAt        DateTime        @default(now())
  createdBy        VbvUser         @relation("CreatedBy", fields: [createdById], references: [id])
  assignedTo       VbvUser?        @relation("AssignedTo", fields: [assignedToId], references: [id])
  submissions      VbvSubmission[]
  timelineLogs     VbvTimelineLog[]
}

enum VbvBriefType {
  timestamp_clip
  full_edit
  vedits
}

enum VbvJobStatus {
  open
  assigned
  in_progress
  submitted
  sent_back_by_lead
  lead_approved
  sent_back_by_sm
  sm_approved
}

model VbvSubmission {
  id              String              @id @default(uuid())
  jobId           String
  editorId        String
  driveLink       String
  editorNotes     String?
  submittedAt     DateTime            @default(now())
  reviewNote      String?
  reviewedAt      DateTime?
  reviewAction    VbvReviewAction?
  smReviewNote    String?
  smReviewedAt    DateTime?
  smReviewAction  VbvSmReviewAction?
  smReviewedById  String?
  job             VbvJob              @relation(fields: [jobId], references: [id])
  editor          VbvUser             @relation(fields: [editorId], references: [id])
  smReviewedBy    VbvUser?            @relation("SmReviewer", fields: [smReviewedById], references: [id])
}

enum VbvReviewAction {
  lead_approved
  sent_back_by_lead
}

enum VbvSmReviewAction {
  sm_approved
  sent_back_by_sm
}

model VbvTimelineLog {
  id        String   @id @default(uuid())
  jobId     String
  actorId   String
  action    String
  note      String?
  createdAt DateTime @default(now())
  job       VbvJob   @relation(fields: [jobId], references: [id])
  actor     VbvUser  @relation(fields: [actorId], references: [id])
}

model VbvActivityLog {
  id         String   @id @default(uuid())
  actorId    String
  actionType String
  detail     String?
  createdAt  DateTime @default(now())
  actor      VbvUser  @relation(fields: [actorId], references: [id])
}

// ── VBV Outreach / CRM ─────────────────────────────────────────────────────

model VbvLead {
  id         String        @id @default(cuid())
  churchName String
  email      String        @unique
  driveLink  String?
  status     VbvLeadStatus
  emailLogs  VbvEmailLog[]
  createdAt  DateTime      @default(now())
  updatedAt  DateTime      @updatedAt
}

enum VbvLeadStatus {
  CONTACTED
  REPLIED
  BOOKED_CALL
  CONVERTED
  NO_RESPONSE
}

model VbvEmailLog {
  id              String            @id @default(cuid())
  direction       VbvEmailDirection
  subject         String?
  body            String
  sentAt          DateTime
  gmailMessageId  String?           @unique
  leadId          String?
  clientId        String?
  lead            VbvLead?          @relation(fields: [leadId], references: [id])
  client          VbvClient?        @relation(fields: [clientId], references: [id])
  createdAt       DateTime          @default(now())
}

enum VbvEmailDirection {
  SENT
  RECEIVED
}

model VbvTemplate {
  id        String   @id @default(cuid())
  name      String
  subject   String
  bodyHtml  String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model VbvClient {
  id         String          @id @default(cuid())
  churchName String
  email      String          @unique
  tier       VbvClientTier
  startDate  DateTime?
  notes      String?
  status     VbvClientStatus
  leadId     String?
  emailLogs  VbvEmailLog[]
  createdAt  DateTime        @default(now())
  updatedAt  DateTime        @updatedAt
}

enum VbvClientTier {
  TIER_1
  TIER_2
  TIER_3
}

enum VbvClientStatus {
  ACTIVE
  PAUSED
  CHURNED
}
