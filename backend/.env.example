# ─── Instagram (Meta Graph API) ───────────────────────────────────────────────
# Long-lived User Access Token or Page Access Token with instagram_basic,
# instagram_manage_insights, pages_show_list, pages_read_engagement scopes.
# Get it from: https://developers.facebook.com/tools/explorer/
INSTAGRAM_ACCESS_TOKEN=

# The numeric ID of your Instagram Business or Creator account.
# Find it via: GET https://graph.facebook.com/v18.0/me/accounts?access_token=YOUR_TOKEN
# Then: GET https://graph.facebook.com/v18.0/{page-id}?fields=instagram_business_account&access_token=YOUR_TOKEN
INSTAGRAM_BUSINESS_ACCOUNT_ID=

# ─── TikTok (Content Posting / Research API) ──────────────────────────────────
# Access token from TikTok for Developers.
# Apply at: https://developers.tiktok.com/
# Scopes needed: user.info.basic, video.list
TIKTOK_ACCESS_TOKEN=
TIKTOK_CLIENT_KEY=
TIKTOK_CLIENT_SECRET=

# ─── YouTube (Data API v3) ────────────────────────────────────────────────────
# API key from Google Cloud Console.
# Enable "YouTube Data API v3" at: https://console.cloud.google.com/apis/library
YOUTUBE_API_KEY=

# Your YouTube channel ID (starts with UC...).
# Find it: YouTube Studio → Settings → Channel → Advanced settings
YOUTUBE_CHANNEL_ID=

# ─── Server ───────────────────────────────────────────────────────────────────
PORT=3001
CACHE_TTL_SECONDS=1800
