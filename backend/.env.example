# Instagram Graph API
INSTAGRAM_BUSINESS_ACCOUNT_ID=
INSTAGRAM_ACCESS_TOKEN=
FACEBOOK_APP_ID=
FACEBOOK_APP_SECRET=
TOKEN_REFRESH_PASSWORD=changeme

# TikTok (optional)
TIKTOK_ACCESS_TOKEN=
TIKTOK_CLIENT_KEY=
TIKTOK_CLIENT_SECRET=

# YouTube (optional)
YOUTUBE_API_KEY=
YOUTUBE_CHANNEL_ID=

# AI
ANTHROPIC_API_KEY=

# Server
PORT=3001
FRAME_INTERVAL_SECONDS=1
CACHE_TTL_SECONDS=1800

# Database — PostgreSQL connection string
DATABASE_URL=postgresql://user:password@host:5432/dbname

# Hetzner Transcription Server
VBV_API_KEY=

# Email — Resend (https://resend.com)
RESEND_API_KEY=
EMAIL_FROM=noreply@yourdomain.com

# VBV Pipeline
JWT_SECRET=change_me_in_production
VBV_DASHBOARD_URL=http://localhost:3001/vbv-pipeline/vbv.html

# Gmail API — inbound reply capture (run scripts/gmailAuth.js to populate the refresh token)
GMAIL_CLIENT_ID=
GMAIL_CLIENT_SECRET=
GMAIL_REFRESH_TOKEN=

# Google Drive ingestion for the Clipping Tool — uses the same OAuth client as
# Gmail above (GMAIL_CLIENT_ID/SECRET), authorized separately with drive.readonly
# scope. Run scripts/driveAuth.js to populate this.
GOOGLE_DRIVE_REFRESH_TOKEN=
